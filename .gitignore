# ── Dependencies ──────────────────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Next.js build output ──────────────────────────────────
.next/
out/
build/
dist/
*.tsbuildinfo
# next dev/build가 자동 재생성. 모드에 따라 ./.next/types/... 와 ./.next/dev/types/... 를 오감.
next-env.d.ts

# ── Environment (never commit) ────────────────────────────
# CLAUDE.md §10 참조: .env.local 은 supabase status / vercel env 로부터 재생성.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.keys

# ── Testing ───────────────────────────────────────────────
coverage/
/test-results/
/playwright-report/
/blob-report/
/playwright/.cache/
.playwright-mcp/

# ── Logs ──────────────────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log
logs/

# ── Vercel CLI (프로젝트 연결 메타) ─────────────────────────
.vercel

# ── Supabase CLI (로컬 컨테이너 런타임 생성 파일) ───────────
# 주의: supabase/config.toml · supabase/migrations(쓰지 않지만 CLI가 생성 시도) 는 커밋.
supabase/.temp/
supabase/.branches/

# ── Drizzle 런타임 (생성 마이그레이션·메타는 커밋) ───────────
# drizzle/ 디렉토리 자체는 추적. drizzle-kit studio 등의 캐시만 제외.
drizzle/.cache/

# ── IDE / Editor ──────────────────────────────────────────
# .vscode/settings.json 만 프로젝트 공용으로 커밋, 나머지는 개인 설정.
.vscode/*
!.vscode/settings.json
.idea/
*.swp
*.swo

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db
ehthumbs.db

# ── Claude Code — per-machine settings only ───────────────
